--- !u!114 &1781924377
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1781924376}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ba0600eb5c35e9742a63bb7ca48ebd52, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueText: {fileID: 569220671}
  dialogues:
  - "Th\xE0nh ph\u1ED1 d\u1EA1o g\u1EA7n \u0111\xE2y kh\xE1 \u1ED3n \xE0o, \u0111\u1EB7c
    bi\u1EC7t l\xE0 v\xE0o ban \u0111\xEAm. T\xF4i \u0111ang t\xECm c\xE1ch c\u1EA3i
    thi\u1EC7n t\xECnh h\xECnh. C\u1EADu ngh\u0129 m\xECnh c\xF3 th\u1EC3 gi\xFAp
    g\xEC kh\xF4ng?"
  - "Th\u01B0a ng\xE0i, v\u1EDBi t\u01B0 c\xE1ch l\xE0 m\u1ED9t sinh vi\xEAn, ch\xE1u
    c\xF3 th\u1EC3 kh\u1EA3o s\xE1t \xFD ki\u1EBFn ng\u01B0\u1EDDi d\xE2n v\xE0 \u0111\u1EC1
    xu\u1EA5t nh\u1EEFng gi\u1EA3i ph\xE1p gi\u1EA3m ti\u1EBFng \u1ED3n ph\xF9 h\u1EE3p
    v\u1EDBi gi\u1EDBi tr\u1EBB v\xE0 khu d\xE2n c\u01B0."
  - "Nghe c\xF3 v\u1EBB h\u1EEFu \xEDch \u0111\u1EA5y. C\u1EADu c\xF3 s\u1EB5n s\xE0ng
    tham gia v\xE0o d\u1EF1 \xE1n n\xE0y kh\xF4ng?"
  - "D\u1EA1, ch\xE1u r\u1EA5t s\u1EB5n l\xF2ng. Ch\xE1u tin r\u1EB1ng n\u1EBFu m\u1ECDi
    ng\u01B0\u1EDDi c\xF9ng h\u1EE3p t\xE1c, th\xE0nh ph\u1ED1 s\u1EBD y\xEAn t\u0129nh
    v\xE0 d\u1EC5 s\u1ED1ng h\u01A1n."
  typingSpeed: 0.04
